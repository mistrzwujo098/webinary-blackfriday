# MailerLite Configuration
NEXT_PUBLIC_MAILERLITE_ACCOUNT_ID=your_mailerlite_account_id

# MailerLite Worker URL (Cloudflare Worker)
MAILERLITE_WORKER_URL=https://your-worker.workers.dev

# MailerLite Group IDs
MAILERLITE_GROUP_ID_E8=your_mailerlite_group_id_e8
MAILERLITE_GROUP_ID_MATURA=your_mailerlite_group_id_matura

# Tracking Configuration (REQUIRED for production)
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your_facebook_pixel_id
NEXT_PUBLIC_GOOGLE_ADS_ID=your_google_ads_id
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# Project Configuration
NEXT_PUBLIC_PROJECT_ID=webinary-blackfriday

# Optional: Server-side Tracking API (Cloudflare Worker)
# NEXT_PUBLIC_TRACKING_WORKER_URL=https://your-tracking-worker.workers.dev

# Development: Enable tracking in dev mode (default: false)
# NEXT_PUBLIC_ENABLE_DEV_TRACKING=true
